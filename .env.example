# PWR Risk Review Coordinator - environment variables
# Copy to .env and fill in real values for local development.

# PostgreSQL connection string used by the backend data layer (Drizzle).
# Local/Replit development provides this automatically.
DATABASE_URL=postgresql://user:password@host:5432/database

# Port the Express API server binds to.
# Precedence at runtime: DATABRICKS_APP_PORT > PORT > 3000.
PORT=3000

# Set by the Databricks App runtime; overrides PORT when present. Leave unset locally.
# DATABRICKS_APP_PORT=

# Node environment. In "production" the API server also serves the built
# React frontend from a single process.
NODE_ENV=development

# Optional override for the directory of built frontend assets served in production.
# Defaults to artifacts/risk-coordinator/dist/public (relative to repo root).
# FRONTEND_DIST=artifacts/risk-coordinator/dist/public

# Base path the frontend is built/served under. Use "/" for single-process
# (Databricks) deployment. Replit dev sets this per-artifact.
BASE_PATH=/

# OIDC authentication (see docs/06-security.md).
# ISSUER_URL=https://replit.com/oidc
# REPL_ID=

# Absolute base URL used for deep links in notification emails (production).
# APP_BASE_URL=

# External UsageTracking API endpoint; unset = forwarding disabled (production-only).
# USAGE_TRACKING_URL=

# Note: Microsoft Graph credentials (tenant/client id, client secret, sender
# mailbox) are NOT environment variables. Admins enter them in-app under
# Admin -> Email Notifications; they are stored in the email_settings table.
